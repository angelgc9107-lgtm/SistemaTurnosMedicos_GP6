@startuml CU5 - Visualizar Agenda

left to right direction
skinparam actorStyle awesome
skinparam packageStyle rectangle
skinparam usecase {
    BackgroundColor #F5F3FF
    BorderColor #7C3AED
    ArrowColor #6D28D9
}

title CU5 - Visualizar Agenda (Diaria / Semanal)

actor "Secretaria" as SEC
actor "Médico" as MED

rectangle "Sistema de Turnos Médicos" {

    usecase "Visualizar Agenda" as CU5

    usecase "Autenticar usuario" as CU5_1
    usecase "Mostrar estados\nde turnos" as CU5_2

    usecase "Ver vista Diaria" as CU5_EXT1
    usecase "Ver vista Semanal" as CU5_EXT2
    usecase "Ver horarios\nbloqueados" as CU5_EXT3
    usecase "Navegar entre\nfechas" as CU5_EXT4

    CU5 ..> CU5_1       : <<include>>
    CU5 ..> CU5_2       : <<include>>

    CU5_EXT1 ..> CU5    : <<extend>>\n[selecciona vista diaria]
    CU5_EXT2 ..> CU5    : <<extend>>\n[selecciona vista semanal]
    CU5_EXT3 ..> CU5    : <<extend>>\n[horario bloqueado\npresente en agenda]
    CU5_EXT4 ..> CU5    : <<extend>>\n[navega fechas]

}

SEC --> CU5
SEC --> CU5_EXT1
SEC --> CU5_EXT2
SEC --> CU5_EXT4

MED --> CU5
MED --> CU5_EXT1
MED --> CU5_EXT2
MED --> CU5_EXT4

note bottom of CU5_2
  Estados visibles:
  • Pendiente
  • Presente / En sala de espera
  • Bloqueado (con motivo)
end note

note right of CU5_EXT1
  Vista por defecto:
  día actual
end note

@enduml
