@startuml CU3 - Reprogramar Turno

left to right direction
skinparam actorStyle awesome
skinparam packageStyle rectangle
skinparam usecase {
    BackgroundColor #FFFBEB
    BorderColor #D97706
    ArrowColor #B45309
}

title CU3 - Reprogramar Turno

actor "Secretaria" as SEC
actor "Paciente" as PAC
actor "Sistema WhatsApp" as WA <<system>>

rectangle "Sistema de Turnos Médicos" {

    usecase "Reprogramar Turno" as CU3

    usecase "Buscar turno\nexistente" as CU3_1
    usecase "Validar disponibilidad\ndel nuevo horario" as CU3_2
    usecase "Liberar horario\nanterior" as CU3_3
    usecase "Bloquear nuevo\nhorario en agenda" as CU3_4
    usecase "Guardar historial\ndel cambio" as CU3_5
    usecase "Enviar notificación\nde reprogramación" as CU3_6

    CU3 ..> CU3_1   : <<include>>
    CU3 ..> CU3_2   : <<include>>
    CU3 ..> CU3_3   : <<include>>
    CU3 ..> CU3_4   : <<include>>
    CU3 ..> CU3_5   : <<include>>
    CU3 ..> CU3_6   : <<include>>

}

PAC ..> CU3     : -->\n[solicita reprogramación]
SEC --> CU3
CU3_6 --> WA

note bottom of CU3_5
  RNF4: Se debe mantener
  historial de todos los
  cambios realizados
end note

note right of CU3_6
  Notifica al paciente el
  nuevo día y horario
  del turno vía WhatsApp
end note

@enduml
