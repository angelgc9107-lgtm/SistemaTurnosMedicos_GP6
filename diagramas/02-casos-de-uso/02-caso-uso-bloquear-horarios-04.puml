@startuml CU4 - Bloquear Días y Horarios

left to right direction
skinparam actorStyle awesome
skinparam packageStyle rectangle
skinparam usecase {
    BackgroundColor #FFF1F2
    BorderColor #E11D48
    ArrowColor #BE123C
}

title CU4 - Bloquear días y horarios en calendario

actor "Secretaria" as SEC
actor "Médico" as MED

rectangle "Sistema de Turnos Médicos" {

    usecase "Bloquear días y\nhorarios en calendario" as CU4

    usecase "Seleccionar rango\nde fechas y horarios" as CU4_1
    usecase "Ingresar motivo\nu observación" as CU4_2
    usecase "Marcar horarios\ncomo no disponibles" as CU4_3

    usecase "Bloquear por\nVacaciones" as CU4_EXT1
    usecase "Bloquear por\nFeriado" as CU4_EXT2
    usecase "Bloquear por\notra actividad" as CU4_EXT3

    CU4 ..> CU4_1       : <<include>>
    CU4 ..> CU4_2       : <<include>>
    CU4 ..> CU4_3       : <<include>>

    CU4_EXT1 ..> CU4    : <<extend>>\n[motivo: vacaciones]
    CU4_EXT2 ..> CU4    : <<extend>>\n[motivo: feriado]
    CU4_EXT3 ..> CU4    : <<extend>>\n[motivo: otra actividad]

}

MED ..> CU4     : <<extend>>\n[indica fechas\na bloquear]
SEC --> CU4
SEC --> CU4_EXT1
SEC --> CU4_EXT2
SEC --> CU4_EXT3

note bottom of CU4_3
  En el calendario se visualiza
  el motivo del bloqueo en
  cada horario no disponible
end note

@enduml
