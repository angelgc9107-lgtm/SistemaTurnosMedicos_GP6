@startuml CU2 - Registrar Check-in

left to right direction
skinparam packageStyle rectangle
skinparam usecase {
    BackgroundColor #F0FDF4
    BorderColor #16A34A
    ArrowColor #15803D
}

title CU2 - Registrar Check-in (Llegada del Paciente)

actor "Secretaria" as SEC
actor "Médico" as MED

rectangle "Sistema de Turnos Médicos" {

    usecase "Registrar Check-in\n(Llegada del Paciente)" as CU2

    usecase "Buscar turno\ndel paciente" as CU2_1
    usecase "Cambiar estado\ndel turno" as CU2_2
    usecase "Registrar hora\nreal de llegada" as CU2_3
    usecase "Visualizar paciente\nen sala de espera" as CU2_EXT

    CU2 ..> CU2_1   : <<include>>
    CU2 ..> CU2_2   : <<include>>
    CU2 ..> CU2_3   : <<include>>
    CU2_EXT ..> CU2 : <<extend>>\n[paciente marcado\ncomo presente]

}

SEC --> CU2
MED --> CU2_EXT

note bottom of CU2_2
  Estado cambia de:
  "Pendiente" → "Presente / En sala de espera"
end note

note right of CU2_EXT
  El médico visualiza en
  su interfaz de agenda
  qué pacientes están
  esperando
end note

@enduml
