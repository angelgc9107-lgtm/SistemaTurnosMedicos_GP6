@startuml CU6 - Cancelar Turno

left to right direction
skinparam packageStyle rectangle
skinparam usecase {
    BackgroundColor #EFF6FF
    BorderColor #3B82F6
    ArrowColor #1D4ED8
}

title CU6 - Cancelar Turno

actor "Secretaria" as SEC
actor "Paciente" as PAC
actor "Sistema WhatsApp" as WA <<system>>

rectangle "Sistema de Turnos Médicos" {

    usecase "Cancelar Turno" as CU6

    usecase "Buscar turno\nen agenda" as CU6_1
    usecase "Seleccionar turno\na cancelar" as CU6_2
    usecase "Confirmar\ncancelación" as CU6_3
    usecase "Liberar horario\nen agenda" as CU6_4
    usecase "Enviar notificación\npor WhatsApp" as CU6_5
    usecase "Guardar historial\ndel cambio" as CU6_6

    CU6 ..> CU6_1 : <<include>>
    CU6 ..> CU6_2 : <<include>>
    CU6 ..> CU6_3 : <<include>>
    CU6 ..> CU6_4 : <<include>>
    CU6 ..> CU6_5 : <<include>>
    CU6 ..> CU6_6 : <<include>>

}

SEC --> CU6
PAC --> CU6
CU6_5 --> WA
WA --> PAC

note bottom of CU6_4
  El horario liberado pasa a estar
  disponible nuevamente en la agenda
end note

note bottom of CU6_6
  RNF4: Se debe mantener
  historial de todos los
  cambios realizados
end note

note right of CU6
  Precondiciones: 
  - La secretaria debe
    estar validada en el sistema.
  - El turno debe estar asignado
    en el calendario.
end note

@enduml
