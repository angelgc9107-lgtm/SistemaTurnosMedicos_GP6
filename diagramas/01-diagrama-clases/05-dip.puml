@startuml 01-solid-05-dip

skinparam classAttributeIconSize 0
title Principio de Inversión de Dependencias (DIP) - Basado en Tarjetas CRC

interface GestorCitas {
    + registrarTurno(t: Turno)
    + cancelarTurno(id: int)
}

interface Notificador {
    + enviarRecordatorio(p: Paciente, mensaje: String)
}


class Recepcionista {
    - gestor: GestorCitas
    + Recepcionista(gestor: GestorCitas)
    + gestionarSolicitudPaciente()
}

class Agenda {
    - notificador: Notificador
    - turnos: List<Turno>
    + Agenda(notificador: Notificador)
    + procesarCita()
}

class Turno {
    - id: int
    - fecha: Date
}

class Paciente {
    - nombre: String
    - contacto: String
}

class NotificadorWhatsApp {
    + enviarRecordatorio(p: Paciente, mensaje: String)
}

Recepcionista --> GestorCitas : "usa"
Agenda ..|> GestorCitas : "realiza"
Agenda --> Notificador : "usa"
Agenda "1" *-- "*" Turno : "contiene"
NotificadorWhatsApp ..|> Notificador : "implementa"
Turno --> Paciente : "asignado a"

note bottom of Agenda
  Inyección de Dependencias:
  Agenda recibe el Notificador por constructor.
end note

@enduml