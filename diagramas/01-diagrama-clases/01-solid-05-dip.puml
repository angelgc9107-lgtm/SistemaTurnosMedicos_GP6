@startuml
interface INotificador {
  + enviarNotificacion(turno: Turno): void
}

class Agenda {
  - notificador: INotificador
  + agendarTurno(turno: Turno): void
}

class NotificadorWhatsApp {
  + enviarNotificacion(turno: Turno): void
}

Agenda --> INotificador
NotificadorWhatsApp ..|> INotificador
@enduml